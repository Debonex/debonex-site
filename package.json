{
  "name": "debonex-site",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "prebuild": "yarn posts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "posts": "ts-node --skip-project --files ./scripts/build-posts.ts ./src/types/posts.d.ts",
    "tailwind": "tailwindcss -o ./src/styles/tailwind.css --watch",
    "tailwind:once": "tailwindcss -o ./src/styles/tailwind.css",
    "preci": "rm -fr node_modules",
    "ci": "yarn install --frozen-lockfile"
  },
  "dependencies": {
    "axios": "^0.26.0",
    "clsx": "^1.1.1",
    "markdown-it": "^12.3.2",
    "markdown-it-container": "^3.0.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-router-dom": "^6.2.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.2",
    "@types/markdown-it": "^12.2.3",
    "@types/markdown-it-container": "^2.0.5",
    "@types/node": "^17.0.17",
    "@types/react": "^17.0.33",
    "@types/react-dom": "^17.0.10",
    "@vitejs/plugin-react": "^1.0.7",
    "autoprefixer": "^10.4.2",
    "less": "^4.1.2",
    "postcss": "^8.4.7",
    "prettier": "^2.5.1",
    "prettier-plugin-tailwindcss": "^0.1.8",
    "tailwindcss": "^3.0.23",
    "typescript": "^4.4.4",
    "vite": "^2.7.2",
    "vite-plugin-svgr": "^1.0.1"
  }
}
